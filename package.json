    "preval.macro": "^5.0.0",
    "react": "^18.3.1",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dnd-scrolling": "^1.3.10",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.7.4",
    "react-router": "^7.17.0",
    "recoil": "^0.7.6",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.0",
    "remark-html": "^16.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unist-builder": "^4.0.0",
    "unist-util-visit": "^5.1.0"
  },
  "scripts": {
    "analyze": "source-map-explorer 'build/static/js/*.js' --no-border-checks",
    "prebuild-backend": "scripts/prebuild-backend.sh",
    "build-backend": "node scripts/build-backend.mjs",
    "build-backend-watch": "npm run build-backend -- --watch",
    "build-frontend": "node scripts/build-frontend.js",
    "build-sam": "sam build --base-dir dist/sam -t dist/template.yaml",
    "build": "npm run build-backend && npm run build-frontend",
    "describe-stacks": "aws cloudformation describe-stacks --stack-name koekalenteri-dev --query Stacks[0] > stack.json",
    "dynamodb:start": "docker compose up -d dynamodb",
    "dynamodb:stop": "docker compose down",
    "dynamodb:seed": "docker compose run --rm dynamodb-seed",
    "lint-backend": "tsc --noEmit -p src/lambda/tsconfig.json",
    "lint-frontend": "tsc --noEmit -p tsconfig.json",
    "lint-biome": "biome check --diagnostic-level=error src",
    "lint": "npm run lint-frontend && npm run lint-backend && npm run lint-biome",
    "format": "biome format --write src",
    "start-backend-build": "npm run build-backend-watch",
    "start-backend-sam": "node scripts/start-sam-with-cloudflared-nginx.js",
    "start-frontend": "node scripts/start-frontend.js",
    "start": "rimraf .aws-sam && concurrently -c auto npm:start-*",
    "test-backend": "node scripts/test-backend.js",
    "test-frontend": "node scripts/test-frontend.js",
    "test": "node scripts/test.js",
    "i18n-compare": "node scripts/compare-translations.js src/i18n/locales/fi/translation.json src/i18n/locales/en/translation.json",
    "i18n-sort": "node scripts/sort-translations.js src/i18n/locales/fi/translation.json && node scripts/sort-translations.js src/i18n/locales/en/translation.json",
    "knip": "knip --config knip.config.json",
    "test-e2e": "npx playwright test",
    "test-e2e:ui": "npx playwright test --ui",
    "test-e2e:debug": "npx playwright test --debug",
    "test-e2e:chrome": "npx playwright test --project=chromium",
    "test-e2e:firefox": "npx playwright test --project=firefox",
    "test-e2e:report": "npx playwright show-report",
    "test-e2e:setup-db": "node -r esbuild-register e2e/scripts/setup-dynamodb.ts",
    "test-e2e:setup-env": "node scripts/setup-e2e-environment.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "prepare": "husky",
  "engines": {
    "npm": ">=11.0.0",
    "node": ">=24.0.0"
  },
  "browserslist": {
    "production": [
      ">5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/runtime": "^7.29.7",
    "@biomejs/biome": "^2.4.16",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@emnapi/core": "1.11.0",
    "@emnapi/runtime": "1.11.0",
    "@jest/globals": "^30.4.1",
    "@playwright/test": "^1.52.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@svgr/webpack": "^8.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/aws-lambda": "^8.10.162",
    "@types/busboy": "^1.5.4",
    "@types/css-mediaquery": "^0.1.2",
    "@types/hast": "^3.0.4",
    "@types/jest": "^30.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/mdast": "^4.0.4",
    "@types/node": "^24.13.2",
    "@types/preval.macro": "^3.0.0",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.7",
    "babel-jest": "^29.7.0",
    "babel-loader": "^10.1.1",
    "babel-preset-react-app": "^10.1.0",
    "camelcase": "^8.0.0",
    "cloudflared": "^0.7.0",
    "concurrently": "^10.0.3",
    "css-loader": "^7.1.4",
    "css-mediaquery": "^0.1.2",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "esbuild-loader": "^4.4.3",
    "esbuild-register": "^3.6.0",
    "file-loader": "^6.2.0",
    "fs-extra": "^11.3.5",
    "html-webpack-plugin": "^5.6.7",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.4.1",
    "jest-fetch-mock": "^3.0.3",
    "jest-watch-typeahead": "^3.0.1",
    "knip": "^5.88.1",
    "mdast-util-to-hast": "^13.2.1",
    "mini-css-extract-plugin": "^2.10.2",
    "playwright": "^1.52.0",
    "react-app-polyfill": "^3.0.0",
    "react-dev-utils": "^12.0.1",
    "react-refresh": "^0.18.0",
    "rimraf": "^6.1.3",
    "semver": "^7.8.4",
    "source-map-explorer": "^2.5.3",
    "source-map-loader": "^5.0.0",
    "style-loader": "^4.0.0",
    "typescript": "^5.9.3",
    "wait-on": "^8.0.3",
    "webpack": "^5.107.2",
    "webpack-dev-server": "^5.2.3",
    "webpack-manifest-plugin": "^5.0.1",
    "workbox-webpack-plugin": "^7.4.1"
  },
  "babel": {
    "presets": [
      "react-app"
    ]
  }
}
